# MongoDB Atlas connection string - get from https://cloud.mongodb.com -> cluster -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/course_collab?retryWrites=true&w=majority

# Random long string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Server port
PORT=5050

# Allowed frontend origin (Vite default)
CLIENT_ORIGIN=http://localhost:5173
