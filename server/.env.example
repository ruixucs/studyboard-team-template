# MongoDB Atlas connection string - get from https://cloud.mongodb.com -> cluster -> Connect -> Drivers
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/studyboard_team?retryWrites=true&w=majority

# Random long string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# Server port
PORT=5050

# Allowed frontend origin (Vite default)
CLIENT_ORIGIN=http://localhost:5173

# Comma-separated emails granted admin powers (e.g. delete any course).
# The dev seed user is included by default so local testing has an admin out-of-the-box.
ADMIN_EMAILS=devuser@mail.mcgill.ca
